<launch>
    <arg name="config_path" default = "$(find-pkg-share vins_estimator)/config/black_box/black_box_config.yaml" />
    <arg name="vins_path" default = "$(find-pkg-share vins_estimator)" />

    <node name="feature_tracker" pkg="feature_tracker" exec="feature_tracker" output="log" launch-prefix="taskset -c 3">
        <param name="config_file" value="$(var config_path)" />
        <param name="vins_folder" value="$(var vins_path)" />
    </node>

    <node name="vins_estimator" pkg="vins_estimator" exec="vins_estimator" output="screen" launch-prefix="taskset -c 1">
        <param name="config_file" value="$(var config_path)" />
        <param name="vins_folder" value="$(var vins_path)" />
    </node>

    <node name="pose_graph" pkg="pose_graph" exec="pose_graph" output="screen" launch-prefix="taskset -c 2">
        <param name="config_file" value="$(var config_path)" />
        <param name="visualization_shift_x" value="0" />
        <param name="visualization_shift_y" value="0" />
        <param name="skip_cnt" value="0" />
        <param name="skip_dis" value="0.1" />
    </node>

</launch>
